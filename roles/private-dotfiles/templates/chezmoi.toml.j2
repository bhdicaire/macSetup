# ============================================================
# ~/.config/chezmoi/chezmoi.toml
# Generated by macSetup on first run — do not edit manually.
# Re-generate: make chezmoi-init
# ============================================================

sourceDir = "{{ home }}/.local/share/chezmoi"

[data]
    name     = "Benoît H. Dicaire"
    email    = "{{ lookup('community.general.onepassword', 'GitHub', field='email', vault='Private') }}"
    hostname = "{{ computer_name | lower }}"

[age]
    identity  = "{{ home }}/.config/chezmoi/key.txt"
    # Public key — safe to commit. Private key is in 1Password only.
    recipient = "{{ age_public_key_line.stdout | replace('# public key: ', '') | default('REPLACE_WITH_YOUR_AGE_PUBLIC_KEY') }}"

[onepassword]
    command = "op"
    prompt  = false

[git]
    autoCommit = false
    autoPush   = false

[diff]
    pager = "delta"

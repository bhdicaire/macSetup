---
# ============================================================
# secrets.yml.example
#
# This file documents the shape of group_vars/secrets.yml
# which is GITIGNORED and generated at runtime via:
#
#   op inject -i group_vars/secrets.yml.tmpl -o group_vars/secrets.yml
#
# Store all values in 1Password items named exactly as shown.
# ============================================================

# macOS sudo password (used for cask installs that require it)
ansible_become_pass: "op://Private/macOS sudo/password"

# AWS credentials (if needed)
# aws_access_key_id:     "op://Private/AWS/access_key_id"
# aws_secret_access_key: "op://Private/AWS/secret_access_key"
# aws_region:            "op://Private/AWS/region"
